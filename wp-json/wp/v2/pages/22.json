0iMSIgaGVpZ2h0PSIxIiB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciPjwvc3ZnPg==\" \/>        <div class=\"media-box1\">\n                    <span class=\"media-info\">\n                8 Years            <\/span>\n        \n                    <p class=\"media-text\">\n                Of Experience            <\/p>\n            <\/div>\n    <div class=\"media-box2\">\n                    <span class=\"media-info\">\n                1500+            <\/span>\n        \n                    <p class=\"media-text\">\n                Happy Clients            <\/p>\n            <\/div>\n<\/div>\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-fda26aa e-con-full e-flex e-con e-child\" data-id=\"fda26aa\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-81f4fc0 elementor-widget__width-initial elementor-widget elementor-widget-travolosectiontitle\" data-id=\"81f4fc0\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"travolosectiontitle.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<!-- Section Title --><div class=\"title-area\" ><span class=\"sec-subtitle\">Welcome to REAL TRIPS\n<\/span><h1 class=\"sec-title title-selector\">We Are The Best For Your Travel\n<\/h1><p class=\"sec-text\">We turn travel dreams into reality with customized journeys tailored to your desires. Whether it\u2019s a beach escape, mountain adventure, or cultural city tour, our experts design perfect itineraries with handpicked stays, activities, and guides. More than just a travel agency, we are your companions in creating unforgettable experiences.<\/p><\/div><!-- End Section Title -->\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-6d8a4a2 elementor-widget elementor-widget-travolochecklist\" data-id=\"6d8a4a2\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"travolochecklist.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t            <ul class=\"about-list1\">\n                                    <li>Domestic Tours<\/li>\n                                    <li>International Tours<\/li>\n                                    <li>Honeymoon Tours<\/li>\n                                    <li>Air Tickets<\/li>\n                                    <li>Hotel Booking<\/li>\n                                    <li>MICE<\/li>\n                                    <li>Passport<\/li>\n                                    <li>Visa<\/li>\n                            <\/ul>\n        \t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-dfc9b06 elementor-widget elementor-widget-travolobutton\" data-id=\"dfc9b06\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"travolobutton.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<!-- Button --><div class=\"btn-wrapper\"><a class=\"vs-btn style7\" href=\"https:\/\/wordpress.vecurosoft.com\/travolo\/contact\/\">View More<\/a><\/div><!-- End Button -->\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-4fe434a e-flex e-con-boxed e-con e-parent\" data-id=\"4fe434a\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t\t<div class=\"e-con-inner\">\n\t\t<div class=\"elementor-element elementor-element-d8e02ea e-con-full e-flex e-con e-child\" data-id=\"d8e02ea\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-5d3451f elementor-widget elementor-widget-heading\" data-id=\"5d3451f\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Mr. Harshad Shinde<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-efe6fa6 elementor-widget elementor-widget-text-editor\" data-id=\"efe6fa6\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t\t\t\t\t\t<p data-start=\"130\" data-end=\"472\">The visionary behind <strong data-start=\"151\" data-end=\"165\">Real Trips<\/strong> has always had a deep-seated passion for travel and exploration. With his extensive eight years of experience and profound love for discovering new cultures and landscapes, he founded Real Trips with a clear mission: to redefine travel experiences and inspire others to embark on transformative journeys.<\/p><p data-start=\"474\" data-end=\"789\">Driven by a belief in the power of travel to broaden horizons and foster connections, he curated a team of like-minded individuals who share his dedication to excellence and personalized service. He brings his expertise to ensure that every itinerary crafted by Real Trips is not only seamless but also enriching.<\/p><p data-start=\"791\" data-end=\"1143\">Through his leadership, Real Trips has become a trusted name in travel, known for creativity, authenticity, and exceptional service. His passion continues to inspire unforgettable journeys worldwide.<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-d0b1248 e-con-full e-flex e-con e-child\" data-id=\"d0b1248\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-0894dc0 elementor-widget elementor-widget-image\" data-id=\"0894dc0\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<img decoding=\"async\" data-src=\"https:\/\/realtrips.thefuturecity.in\/wp-content\/uploads\/2025\/12\/harshad-shinde-1.png\" title=\"harshad shinde\" alt=\"harshad shinde\" src=\"data:image\/svg+xml;base64,PHN2ZyB3aWR0aD0iMSIgaGVpZ2h0PSIxIiB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmci